# ---- AI (Antigravity — routes to Claude models + nanobanana2) ----
# Get these from your Antigravity dashboard
ANTIGRAVITY_BASE_URL=https://api.antigravity.ai
ANTIGRAVITY_API_KEY=ag-...

# Legacy — kept for SDK compat; Antigravity key is used instead via baseURL override
ANTHROPIC_API_KEY=

# ---- Auth (Auth.js v5) ----
# Generate AUTH_SECRET with:  npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=replace-with-a-long-random-string

# Google OAuth (FREE) — Google Cloud Console → APIs & Services → Credentials →
# OAuth client ID (Web). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google   (+ your prod URL)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Facebook Login (FREE) — Meta for Developers → create app → Facebook Login →
# Valid OAuth Redirect URI:
#   http://localhost:3000/api/auth/callback/facebook   (+ your prod URL)
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# Apple Sign In is NOT enabled — it requires the paid Apple Developer Program
# ($99/yr). Add a next-auth Apple provider only if you take that on.

# Allow the email-only dev sign-in in a deployed/preview env (always on in dev).
# Set BOTH so the server accepts it and the sign-in page renders the dev form.
ALLOW_DEV_LOGIN=false
NEXT_PUBLIC_ALLOW_DEV_LOGIN=false

# ---- Database (Postgres: Neon / Supabase / Vercel Postgres — all free tiers) ----
# Neon (recommended, simplest): neon.tech → new project → copy connection string.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ---- Connectors ----
# ACRA entity data is published on data.gov.sg. Each dataset (by company-name
# first letter) has its own resource id; set the one(s) you query, or point at
# your own ingested table. See src/lib/acra.ts.
ACRA_RESOURCE_ID=
GOOGLE_PLACES_API_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ---- Storage (Vercel Blob) ----
BLOB_READ_WRITE_TOKEN=

# ---- Jobs (Inngest) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
